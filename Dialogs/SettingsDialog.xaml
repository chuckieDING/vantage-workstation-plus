<Window x:Class="VantageWorkstationPlus.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="560" Height="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource B.Bg}"
        FontFamily="{StaticResource F.Default}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="36" Background="{StaticResource B.Surface}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="设置" Style="{StaticResource T.Caption}"
                       VerticalAlignment="Center" Margin="16,0"
                       MouseLeftButtonDown="Title_DragWindow" />
            <Button Grid.Column="1" Content="✕" Style="{StaticResource Btn.Ghost}"
                    MinWidth="46" MinHeight="36" Click="BtnCancel_Click" />
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="20">
            <StackPanel>
                <TextBlock Text="服务器配置" Style="{StaticResource T.H3}" Margin="0,0,0,12" />

                <TextBlock Text="服务器地址 (BaseUrl)" Style="{StaticResource T.Label}" Margin="0,0,0,6" />
                <TextBox x:Name="txtBaseUrl" Margin="0,0,0,14" />

                <TextBlock Text="工作站 ID (WorkCellId)" Style="{StaticResource T.Label}" Margin="0,0,0,6" />
                <TextBox x:Name="txtWorkCellId" Margin="0,0,0,4" />
                <TextBlock Text="改 WorkCellId 需重启程序生效。0 表示未配置（启动时会列出可用 ID）。"
                           Style="{StaticResource T.Caption}" Margin="0,0,0,14" />

                <CheckBox x:Name="chkAcceptAnyCert" Content="接受任意 TLS 证书（自签内网常用）"
                          Margin="0,0,0,16" />

                <TextBlock Text="启用的功能 Tab" Style="{StaticResource T.H3}" Margin="0,8,0,12" />
                <StackPanel>
                    <CheckBox x:Name="chkSignoff" Content="批量出片 (signoff)" Margin="0,3" />
                    <CheckBox x:Name="chkDehydration" Content="批量脱水 (dehydration)" Margin="0,3" />
                    <CheckBox x:Name="chkArchive" Content="批量归档 (archive)" Margin="0,3" />
                    <CheckBox x:Name="chkTransfer" Content="批量流转 (transfer)" Margin="0,3" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,20,20">
            <Button x:Name="btnSave" Content="保存（重启生效）" Style="{StaticResource Btn.Primary}"
                    MinWidth="140" Margin="0,0,8,0" Click="BtnSave_Click" />
            <Button x:Name="btnCancel" Content="取消" Style="{StaticResource Btn.Secondary}"
                    MinWidth="80" Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
