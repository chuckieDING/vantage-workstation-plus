<UserControl x:Class="VantageWorkstationPlus.Panels.DehydrationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,28" MaxWidth="1400" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="批量脱水" Style="{StaticResource T.H1}" />
            <TextBlock Text="Tissue Processing — 选择脱水机/缸/框，导入包埋盒后启动脱水"
                       Style="{StaticResource T.Caption}" Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 设备选择 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="脱水机" Style="{StaticResource T.Label}" Margin="0,0,0,6" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="脱水缸" Style="{StaticResource T.Label}" Margin="12,0,0,6" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="脱水框" Style="{StaticResource T.Label}" Margin="12,0,0,6" />
                    <ComboBox Grid.Row="1" Grid.Column="0" x:Name="cboProcessor"
                              SelectionChanged="CboProcessor_SelectionChanged" />
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cboRetort" Margin="12,0,0,0" />
                    <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cboBasket" Margin="12,0,0,0"
                              SelectionChanged="CboBasket_SelectionChanged" />
                    <Button Grid.Row="1" Grid.Column="3" Content="刷新设备" Style="{StaticResource Btn.Secondary}"
                            Click="BtnRefreshDevices_Click" Margin="12,0,0,0" />
                </Grid>

                <!-- 状态详情 -->
                <Border Grid.Row="1" Margin="0,16,0,0" CornerRadius="6"
                        BorderBrush="{StaticResource B.Border}" BorderThickness="1"
                        Background="{StaticResource B.SurfaceAlt}">
                    <StackPanel Margin="14,10">
                        <TextBlock x:Name="lblProcessorStatus" Style="{StaticResource T.Label}" />
                        <TreeView x:Name="treeStatus" BorderThickness="0" Background="Transparent"
                                  MaxHeight="180" Margin="0,6,0,0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>

                <!-- 文件 -->
                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="Auto" MinWidth="280" MaxWidth="640" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="包埋盒文件" Style="{StaticResource T.Label}" />
                    <TextBox Grid.Column="1" x:Name="txtFile" IsReadOnly="True" Margin="0,0,12,0"
                             HorizontalScrollBarVisibility="Auto" />
                    <Button Grid.Column="2" Content="选择..." Style="{StaticResource Btn.Secondary}"
                            Click="BtnBrowse_Click" />
                </Grid>

                <!-- 包埋盒预览 -->
                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="lblPreview" Text="包埋盒预览（待添加）" Style="{StaticResource T.Label}"
                                   Margin="0,0,0,6" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button x:Name="btnAddCassettes" Content="添加包埋盒到框"
                                    Style="{StaticResource Btn.Secondary}" MinWidth="120" Margin="0,0,6,0"
                                    Click="BtnAddCassettes_Click" />
                            <Button x:Name="btnRemoveSelected" Content="移除选中"
                                    Style="{StaticResource Btn.Secondary}" MinWidth="80" Margin="0,0,6,0"
                                    Click="BtnRemoveSelected_Click" />
                            <Button x:Name="btnClearBasket" Content="清空脱水框"
                                    Style="{StaticResource Btn.Secondary}" MinWidth="90"
                                    Click="BtnClearBasket_Click" />
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6"
                            MinHeight="80" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource B.SurfaceAlt}">
                            <ListBox x:Name="lstObjects" BorderThickness="0" Background="Transparent"
                                     SelectionMode="Extended" Padding="8">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="3" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="bd" CornerRadius="14" Padding="12,5"
                                                            Background="{StaticResource B.Surface}"
                                                            BorderBrush="{StaticResource B.BorderStrong}"
                                                            BorderThickness="1">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="BorderBrush"
                                                                    Value="{StaticResource B.Accent}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="bd" Property="Background"
                                                                    Value="{StaticResource B.Accent}" />
                                                            <Setter TargetName="bd" Property="BorderBrush"
                                                                    Value="{StaticResource B.Accent}" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- 时长 -->
                <Grid Grid.Row="4" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="脱水时长" Style="{StaticResource T.Label}" />
                    <StackPanel Grid.Column="1" Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton x:Name="rbDuration" Content="持续时间" GroupName="TimeMode"
                                         IsChecked="True" Margin="0,0,16,0" Width="80" />
                            <TextBox x:Name="txtHours" Width="60" Text="3" />
                            <TextBlock Text="小时" Style="{StaticResource T.Body}" VerticalAlignment="Center" Margin="6,0,12,0" />
                            <TextBox x:Name="txtMinutes" Width="60" Text="0" />
                            <TextBlock Text="分钟" Style="{StaticResource T.Body}" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbEndTime" Content="结束时间" GroupName="TimeMode"
                                         Margin="0,0,16,0" Width="80" />
                            <DatePicker x:Name="dpEndDate" Width="140" />
                            <TextBox x:Name="txtEndTime" Width="80" Text="08:00" Margin="6,0,0,0"
                                     ToolTip="HH:mm，例如 08:30" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- 按钮 + 进度 -->
                <Grid Grid.Row="5" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnStart" Content="开始脱水"
                                Style="{StaticResource Btn.Primary}"
                                Click="BtnStart_Click" MinWidth="120" Margin="0,0,8,0" />
                        <Button x:Name="btnEnd" Content="结束脱水"
                                Style="{StaticResource Btn.Danger}"
                                Click="BtnEnd_Click" MinWidth="120" Margin="0,0,16,0" />
                    </StackPanel>
                    <ProgressBar Grid.Column="1" x:Name="progress" Minimum="0" Value="0" VerticalAlignment="Center" />
                    <Button Grid.Column="2" x:Name="btnCancel" Content="中止" IsEnabled="False"
                            Style="{StaticResource Btn.Secondary}" MinWidth="60" Margin="12,0,0,0"
                            Click="BtnCancel_Click" />
                </Grid>

                <TextBlock Grid.Row="6" Text="操作日志" Style="{StaticResource T.Label}" Margin="0,16,0,6" />
                <Border Grid.Row="7" BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6"
                        Background="{StaticResource B.SurfaceAlt}">
                    <ScrollViewer x:Name="logScroll" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="logBox" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                 FontFamily="{StaticResource F.Mono}" FontSize="12" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
