<Window x:Class="VantageWorkstationPlus.ConfigTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据源配置 — Histology Workstation Plus"
        Width="1100" Height="720"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI, PingFang SC, Microsoft YaHei UI, sans-serif"
        FontSize="13"
        Background="#F4F6F8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="数据源配置" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Margin="0,4,0,0" Foreground="#5C6470">
                <Run Text="编辑保存到：" />
                <Run x:Name="lblFilePath" Text="" FontFamily="Cascadia Mono, Consolas" />
            </TextBlock>
        </StackPanel>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="+ 新建" MinWidth="80" Padding="12,6" Margin="0,0,8,0"
                    Click="BtnAdd_Click" />
            <Button x:Name="btnDelete" Content="删除" MinWidth="60" Padding="12,6" Margin="0,0,8,0"
                    IsEnabled="False" Click="BtnDelete_Click" />
            <Button x:Name="btnTest" Content="测试连接" MinWidth="80" Padding="12,6" Margin="0,0,8,0"
                    IsEnabled="False" Click="BtnTest_Click" />
            <Button x:Name="btnRunOnce" Content="立即抽取一次" MinWidth="110" Padding="12,6" Margin="0,0,8,0"
                    IsEnabled="False" Click="BtnRunOnce_Click" />
            <Button x:Name="btnEncrypt" Content="加密密码…" MinWidth="100" Padding="12,6"
                    ToolTip="弹框输密码，输出可直接粘到连接串里的 DPAPI:xxx"
                    Click="BtnEncrypt_Click" />
        </StackPanel>

        <!-- 主区域：左列表 + 右详情 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左：数据源列表 -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E1E5EA" BorderThickness="1"
                    CornerRadius="6">
                <ListBox x:Name="lstSources" BorderThickness="0" Background="Transparent"
                         SelectionChanged="LstSources_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock FontSize="11" Foreground="#5C6470">
                                    <Run Text="{Binding Provider, Mode=OneWay}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding TargetPanel, Mode=OneWay}" />
                                    <Run Text="  " />
                                    <Run Text="{Binding CronOrInterval, Mode=OneWay}" Foreground="#0F6CBD" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- 右：详情 -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E1E5EA" BorderThickness="1"
                    CornerRadius="6" Margin="12,0,0,0" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="pnlDetail" IsEnabled="False">
                        <TextBlock Text="基本" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="名称" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4" />
                            <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Padding="6,4" Margin="0,4" />

                            <TextBlock Text="数据库类型" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4" />
                            <ComboBox x:Name="cboProvider" Grid.Row="1" Grid.Column="1" Padding="6,4" Margin="0,4"
                                      SelectionChanged="CboProvider_SelectionChanged">
                                <ComboBoxItem Content="SqlServer" />
                                <ComboBoxItem Content="MySql" />
                                <ComboBoxItem Content="Postgres" />
                                <ComboBoxItem Content="Sqlite" />
                                <ComboBoxItem Content="Oracle" />
                            </ComboBox>

                            <TextBlock Text="目标功能 Tab" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,4" />
                            <ComboBox x:Name="cboTargetPanel" Grid.Row="2" Grid.Column="1" Padding="6,4" Margin="0,4">
                                <ComboBoxItem Tag="signoff" Content="出片 (Assembling)" />
                                <ComboBoxItem Tag="dehydration" Content="脱水 (Tissue Processing)" />
                                <ComboBoxItem Tag="archive" Content="归档 (Archiving)" />
                                <ComboBoxItem Tag="transfer" Content="流转 (Tracking)" />
                            </ComboBox>

                            <TextBlock Text="定时间隔" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,4" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                                <TextBox x:Name="txtCron" Width="120" Padding="6,4" />
                                <TextBlock Text="（如 30m / 2h；留空 = 仅手动）" VerticalAlignment="Center"
                                           Foreground="#8B95A1" Margin="8,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="连接" FontWeight="SemiBold" Margin="0,8,0,8" />
                        <TextBlock Text="连接串（密码用 DPAPI:xxx 形式；点上面「加密密码…」生成）"
                                   Foreground="#5C6470" Margin="0,0,0,4" />
                        <TextBox x:Name="txtConnStr" Padding="6,4" TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="60" Margin="0,0,0,12" />

                        <TextBlock Text="查询" FontWeight="SemiBold" Margin="0,8,0,8" />
                        <TextBlock Text="SQL（占位符 {date} / {today} / {now} / {user}）"
                                   Foreground="#5C6470" Margin="0,0,0,4" />
                        <TextBox x:Name="txtQuery" Padding="6,4" TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="100" FontFamily="Cascadia Mono, Consolas" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="ID 列名" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4" />
                            <TextBox x:Name="txtIdCol" Grid.Row="0" Grid.Column="1" Padding="6,4" Margin="0,4" />

                            <TextBlock Text="辅助列（逗号分隔）" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4" />
                            <TextBox x:Name="txtAuxCols" Grid.Row="1" Grid.Column="1" Padding="6,4" Margin="0,4" />
                        </Grid>

                        <TextBlock Text="上次运行" FontWeight="SemiBold" Margin="0,8,0,4" />
                        <TextBlock x:Name="lblLastRun" Text="—" Foreground="#5C6470" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <TextBlock x:Name="lblStatus" VerticalAlignment="Center" Margin="0,0,16,0"
                       Foreground="#5C6470" />
            <Button Content="保存到 appsettings.json" Padding="14,6" MinWidth="160" FontWeight="SemiBold"
                    Background="#0F6CBD" Foreground="White" BorderBrush="#0F6CBD"
                    Click="BtnSave_Click" />
        </StackPanel>
    </Grid>
</Window>
